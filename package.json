{
  "name": "kosmyn-books",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3010",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:install": "playwright install --with-deps chromium",
    "postinstall": "node -e \"const fs=require('fs');const src=fs.existsSync('node_modules/pdfjs-dist/build/pdf.worker.mjs')?'node_modules/pdfjs-dist/build/pdf.worker.mjs':'node_modules/pdfjs-dist/legacy/build/pdf.worker.mjs';try{fs.copyFileSync(src,'public/pdf.worker.js');fs.copyFileSync(src,'public/pdf.worker.mjs')}catch(e){console.warn('pdf.worker not copied:',e.message)}\""
  },
  "dependencies": {
    "@kosmynapp/tokens": "^1.0.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.575.0",
    "next": "16.1.6",
    "pdfjs-dist": "5.4.296",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-pdf": "^10.4.1",
    "semver": "^7.7.4",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/semver": "^7.7.1",
    "@vitejs/plugin-react": "^5.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "happy-dom": "^20.1.0",
    "tailwindcss": "^4",
    "typescript": "^5.7.3",
    "vitest": "^3.2.4"
  }
}
